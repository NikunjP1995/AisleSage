{
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "https://api.anthropic.com/v1/messages"
    }
  ],
  "headers": [
    {
      "source": "/api/chat",
      "headers": [
        {"key": "x-api-key", "value": "YOUR_ANTHROPIC_KEY_HERE"},
        {"key": "anthropic-version", "value": "2023-06-01"}
      ]
    }
  ]
}
